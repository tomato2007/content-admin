APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

# PostgreSQL app database.
# Use DATABASE_URL when possible; PG* variables are supported as compatibility fallbacks.
DATABASE_URL=
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=content_admin
PGUSER=content_admin
PGPASSWORD=
PGSSLMODE=disable

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=content_admin
DB_USERNAME=content_admin
DB_PASSWORD=
DB_SCHEMA=public
DB_SSLMODE=disable

TELEGRAM_RUNTIME_DATABASE_URL=
TELEGRAM_RUNTIME_DB_HOST=127.0.0.1
TELEGRAM_RUNTIME_DB_PORT=5432
TELEGRAM_RUNTIME_DB_DATABASE=content_admin
TELEGRAM_RUNTIME_DB_USERNAME=content_admin
TELEGRAM_RUNTIME_DB_PASSWORD=
TELEGRAM_RUNTIME_DB_SCHEMA=public
TELEGRAM_RUNTIME_DB_SSLMODE=disable
TELEGRAM_RUNTIME_CONNECTION=telegram_runtime
TELEGRAM_CHANNEL_CONFIG_TABLE=telegram_channel_configs
TELEGRAM_PUBLISHER_DRIVER=null
TELEGRAM_PUBLISH_SCRIPT_PATH=

# External Postgres source described in docs/prod-db.md.
POSTS_SOURCE_CONNECTION=posts_source
POSTS_SOURCE_DATABASE_URL=
POSTS_SOURCE_DB_HOST=127.0.0.1
POSTS_SOURCE_DB_PORT=5432
POSTS_SOURCE_DB_DATABASE=anecdots
POSTS_SOURCE_DB_USERNAME=content_admin
POSTS_SOURCE_DB_PASSWORD=
POSTS_SOURCE_DB_SCHEMA=public
POSTS_SOURCE_DB_SSLMODE=disable
POSTS_SOURCE_SCHEMA=public
POSTS_SOURCE_TABLE=posts
POSTS_SOURCE_QUALIFIED_TABLE=public.posts
POSTS_SOURCE_CONTENT_COLUMN=content
POSTS_SOURCE_MEDIA_URL_COLUMN=media_url
POSTS_SOURCE_PUBLISHED_AT_COLUMN=published_at
POSTS_SOURCE_MAX_POSTS_PER_RUN=1
POSTS_SOURCE_QUIET_HOURS_START_UTC=00:00
POSTS_SOURCE_QUIET_HOURS_END_UTC=06:00

LOCAL_DEV_ADMIN_NAME="Local Admin"
LOCAL_DEV_ADMIN_EMAIL=admin@local.test
LOCAL_DEV_ADMIN_PASSWORD=admin12345

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="dev@content-admin.local"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
